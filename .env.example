# Unlimited Email API Configuration
# Add multiple providers for unlimited free emails

# Required: API Key for authentication
API_KEY=your-secure-api-key-change-in-production

# ========== PROVIDER 1: Resend.com (3000 emails/month free) ==========
# Get API key: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_SENDER=onboarding@resend.dev

# ========== PROVIDER 2: Gmail SMTP (500 emails/day free) ==========
# Your Gmail address
GMAIL_USER=your-email@gmail.com
# Gmail App Password (16 chars, NOT regular password)
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_PASS=xxxx xxxx xxxx xxxx

# ========== PROVIDER 3: Outlook SMTP (300 emails/day free) ==========
OUTLOOK_USER=your-email@outlook.com
OUTLOOK_PASS=your-outlook-password

# ========== PROVIDER 4: Yahoo SMTP (500 emails/day free) ==========
YAHOO_USER=your-email@yahoo.com
YAHOO_PASS=your-yahoo-password

# ========== PROVIDER 5: Zoho SMTP (200 emails/day free) ==========
ZOHO_USER=your-email@zoho.com
ZOHO_PASS=your-zoho-password

# ========== Rate Limiting ==========
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW=60

# ========== CORS & Debug ==========
CORS_ORIGINS=*
DEBUG=false
